{:paths ["src"]

 ;; ACP is a module (the :isaac/cli berth + comm impl). It depends on the
 ;; split platform repos — agent (runtime: bridge, drive, llm, sessions,
 ;; tools), server (routes), foundation (cli/loader/config/nexus, transitive)
 ;; — NOT the legacy monolith.
 :deps  {io.github.slagyr/isaac-foundation {:git/url "https://github.com/slagyr/isaac-foundation.git"
                                            :git/sha "e196584a24052f2d6f02a1c620130b5c1d01d57c"}
         io.github.slagyr/isaac-agent      {:git/url "https://github.com/slagyr/isaac-agent.git"
                                            :git/sha "1afb347a438e3d8e0f711b1ad14bc03236abc269"}
         io.github.slagyr/isaac-server     {:git/url "https://github.com/slagyr/isaac-server.git"
                                            :git/sha "6ad8131e04db8b2a641b092903e162298b63938f"}
         ;; acp's websocket comm directly uses org.httpkit.server + ring.util.codec
         ;; (transitive via the monolith before the split — now declared here).
         clout/clout                 {:mvn/version "1.1.0"}
         com.cleancoders.c3kit/apron {:mvn/version "3.0.0"}
         cheshire/cheshire           {:mvn/version "5.13.0"}
         http-kit/http-kit           {:mvn/version "2.8.0"}
         ring/ring-codec             {:mvn/version "1.2.0"}
         org.babashka/http-client    {:mvn/version "0.4.22"}
         org.clojure/tools.cli       {:mvn/version "1.1.230"}}

 :aliases
 {:dev-local {:override-deps {io.github.slagyr/isaac-agent                   {:local/root "../isaac-agent"}
                              io.github.slagyr/isaac-server                  {:local/root "../isaac-server"}
                              io.github.slagyr/isaac-foundation              {:local/root "../isaac-foundation"}
                              io.github.slagyr/isaac-foundation-spec         {:local/root "../isaac-foundation/spec"}
                              io.github.slagyr/isaac-foundation-test-support {:local/root "../isaac-foundation/spec-support"}
                              io.github.slagyr/isaac-server-test-support     {:local/root "../isaac-server/spec-support"}
                              marigold.bridge/marigold.bridge                {:local/root "../isaac-foundation/modules/marigold.bridge"}
                              marigold.longwave/marigold.longwave            {:local/root "../isaac-foundation/modules/marigold.longwave"}}}

  :spec {:extra-paths ["spec" "../isaac-agent/spec"]
         :extra-deps  {io.github.slagyr/isaac-foundation-spec         {:git/url   "https://github.com/slagyr/isaac-foundation.git"
                                                                       :git/sha   "e196584a24052f2d6f02a1c620130b5c1d01d57c"
                                                                       :deps/root "spec"}
                       io.github.slagyr/isaac-foundation-test-support {:git/url   "https://github.com/slagyr/isaac-foundation.git"
                                                                       :git/sha   "e196584a24052f2d6f02a1c620130b5c1d01d57c"
                                                                       :deps/root "spec-support"}
                       io.github.slagyr/isaac-server-test-support     {:git/url   "https://github.com/slagyr/isaac-server.git"
                                                                       :git/sha   "6ad8131e04db8b2a641b092903e162298b63938f"
                                                                       :deps/root "spec-support"}
                       speclj/speclj            {:mvn/version "3.13.0"}
                       babashka/process         {:mvn/version "0.5.22"}
                       io.github.slagyr/gherclj {:git/tag "v1.3.0" :git/sha "9c3bb1d"}}
         :main-opts   ["-m" "speclj.main" "-c" "-D" "spec"]}

  :features {:extra-paths ["spec" "../isaac-agent/spec"]
             :extra-deps  {io.github.slagyr/isaac-server-test-support     {:git/url   "https://github.com/slagyr/isaac-server.git"
                                                                           :git/sha   "6ad8131e04db8b2a641b092903e162298b63938f"
                                                                           :deps/root "spec-support"}
                           io.github.slagyr/isaac-foundation-spec         {:git/url   "https://github.com/slagyr/isaac-foundation.git"
                                                                           :git/sha   "e196584a24052f2d6f02a1c620130b5c1d01d57c"
                                                                           :deps/root "spec"}
                           speclj/speclj                {:mvn/version "3.13.0"}
                           babashka/process             {:mvn/version "0.5.22"}
                           io.github.slagyr/gherclj     {:git/tag "v1.3.0" :git/sha "9c3bb1d"}
                           io.github.cleancoders/c3kit-wire {:git/tag "2.5.1" :git/sha "1fae444"}
                           org.babashka/http-client     {:mvn/version "0.4.22"}
                           marigold.bridge/marigold.bridge     {:git/url   "https://github.com/slagyr/isaac-foundation.git"
                                                                :git/sha   "e196584a24052f2d6f02a1c620130b5c1d01d57c"
                                                                :deps/root "modules/marigold.bridge"}
                           marigold.longwave/marigold.longwave {:git/url   "https://github.com/slagyr/isaac-foundation.git"
                                                                :git/sha   "e196584a24052f2d6f02a1c620130b5c1d01d57c"
                                                                :deps/root "modules/marigold.longwave"}
                           isaac.comm.telly/isaac.comm.telly   {:local/root "../isaac-agent/modules/isaac.comm.telly"}}
             :main-opts   ["-m" "gherclj.main"
                           "-f" "features"
                           "-s" "isaac.**-steps"
                           "-t" "~slow"
                           "-t" "~wip"]}}}
