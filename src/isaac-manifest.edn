{:id          :isaac.comm.acp
 :version     "0.1.0"
 :description "ACP (Agent Communication Protocol) for isaac — stdio agent surface, WebSocket transport, and the chat TUI launcher."

 ;; HTTP route registered on the isaac server when the module is activated.
 ;; Discord and other websocket clients use /acp as the gateway.
 :route       {[:get "/acp"] isaac.comm.acp.websocket/handler}

 ;; CLI subcommands the module contributes via the :cli extension kind. The
 ;; factory function (zero-arity) returns the full command spec, including :name.
 :cli         {:acp  {:factory     isaac.comm.acp.cli/make-command
                      :description "Run Isaac as an ACP agent over stdio"}
               :chat {:factory     isaac.comm.acp.chat-cli/make-command
                      :description "Launch Toad chat UI"}}}
