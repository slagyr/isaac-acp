{:tasks
 ;; Tests run via JVM clojure aliases (deps.edn :spec / :features), matching
 ;; the sibling consumers (cron/hail). When a ../isaac-agent checkout exists,
 ;; the :dev-local alias overrides the pinned agent/server/foundation deps with
 ;; local siblings so cross-repo edits land without pushing. Set ISAAC_GIT=1 to
 ;; force the pinned git shas even when siblings exist.
 {:init (def ^:private alias-prefix
          (if (and (not (System/getenv "ISAAC_GIT"))
                   (babashka.fs/exists? "../isaac-agent"))
            "-M:dev-local"
            "-M"))

  spec     {:doc  "Run ACP unit specs"
            :task (apply shell "clojure" (str alias-prefix ":spec") *command-line-args*)}

  features {:doc  "Run ACP features (excludes @slow and @wip)"
            :task (do (babashka.fs/delete-tree "target")
                      (apply shell "clojure" (str alias-prefix ":features") *command-line-args*))}

  ci       {:doc  "Run all specs and features"
            :task (do (shell "bb" "spec")
                      (shell "bb" "features"))}

  clean    {:doc  "Remove the target/ build dir (gherclj-generated specs, etc.)"
            :task (babashka.fs/delete-tree "target")}}}
